apm log-setting default-log-setting {
    access {
        general-log {
            app-service none
            enabled true
            publisher sys-db-access-publisher
            type access
            log-level {
                access-control notice
                access-per-request notice
                adfs-proxy notice
                api-protection notice
                apm-acl notice
                eca notice
                endpoint-management-system notice
                ftp notice
                htconnector notice
                imap notice
                oauth notice
                paa notice
                pop3 notice
                smtps notice
                ssl-orchestrator notice
                sso notice
                swg notice
                vdi notice
                webssh notice
            }
        }
    }
    app-service none
    description "Default log setting for all APM messages."
    partition Common
    url-filters {
        urlf {
            app-service none
            enabled true
            publisher local-db-publisher
            filter {
                log-allowed-url false
                log-blocked-url true
                log-confimed-url true
            }
        }
    }
}
